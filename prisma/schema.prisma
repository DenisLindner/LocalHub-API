generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  avatarUrl    String?
  status       UserStatus @default(ACTIVE)

  emailVerifiedAt DateTime?
  lastLoginAt      DateTime?

  memberships        OrganizationMember[]
  ownedOrganizations Organization[]       @relation("OrganizationOwner")

  createdTasks  Task[] @relation("TaskCreator")
  assignedTasks Task[] @relation("TaskAssignee")

  createdContentPlans ContentPlan[] @relation("ContentPlanCreator")

  refreshTokens RefreshToken[]
  activityLogs  ActivityLog[] @relation("ActivityActor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id        String @id @default(cuid())
  userId    String
  tokenHash String @unique

  expiresAt DateTime
  revokedAt DateTime?

  userAgent String?
  ipAddress String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ARCHIVED
}

enum OrganizationSize {
  SOLO
  TWO_TO_FIVE
  SIX_TO_TEN
  ELEVEN_TO_TWENTY
  TWENTY_PLUS
}

model Organization {
  id      String @id @default(cuid())
  name    String
  slug    String @unique
  segment String?

  size  OrganizationSize?
  city  String?
  state String?

  status OrganizationStatus @default(ACTIVE)

  ownerId String
  owner   User   @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Restrict)

  members         OrganizationMember[]
  customers       Customer[]
  productServices ProductService[]
  tasks           Task[]
  contentPlans    ContentPlan[]
  subscription    Subscription?
  activityLogs    ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([slug])
  @@index([status])
  @@map("organizations")
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum OrganizationMemberStatus {
  INVITED
  ACTIVE
  DISABLED
}

model OrganizationMember {
  id             String                   @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole         @default(MEMBER)
  status         OrganizationMemberStatus @default(ACTIVE)

  joinedAt DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, role])
  @@index([organizationId, status])
  @@map("organization_members")
}

enum CustomerStatus {
  ACTIVE
  ARCHIVED
}

model Customer {
  id             String @id @default(cuid())
  organizationId String

  name     String
  email    String?
  phone    String?
  document String?
  notes    String?

  status CustomerStatus @default(ACTIVE)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, email])
  @@unique([organizationId, document])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, name])
  @@map("customers")
}

enum ProductServiceType {
  PRODUCT
  SERVICE
}

enum ProductServiceStatus {
  ACTIVE
  ARCHIVED
}

model ProductService {
  id             String @id @default(cuid())
  organizationId String

  name        String
  description String?
  type        ProductServiceType
  price       Decimal            @db.Decimal(10, 2)
  status      ProductServiceStatus @default(ACTIVE)
  category    String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, type])
  @@index([organizationId, status])
  @@index([organizationId, category])
  @@map("product_services")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id             String @id @default(cuid())
  organizationId String

  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?

  createdById  String
  assignedToId String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdBy  User  @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assignedTo User? @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, priority])
  @@index([organizationId, assignedToId])
  @@index([organizationId, dueDate])
  @@map("tasks")
}

enum ContentPlanStatus {
  DRAFT
  APPROVED
  ARCHIVED
}

model ContentPlan {
  id             String @id @default(cuid())
  organizationId String

  name          String
  referenceWeek DateTime
  objective     String?
  targetAudience String?
  status        ContentPlanStatus @default(DRAFT)

  createdById String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("ContentPlanCreator", fields: [createdById], references: [id], onDelete: Restrict)

  posts ContentPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, referenceWeek])
  @@map("content_plans")
}

enum ContentPostType {
  FEED_POST
  REELS
  STORY
  CAROUSEL
  SHORT_VIDEO
}

enum ContentChannel {
  INSTAGRAM
  TIKTOK
  YOUTUBE
  LINKEDIN
}

enum ContentPostStatus {
  IDEA
  IN_PRODUCTION
  READY
  PUBLISHED
  CANCELED
}

model ContentPost {
  id            String @id @default(cuid())
  contentPlanId String

  title         String
  type          ContentPostType
  channel       ContentChannel
  caption       String?
  cta           String?
  visualIdea    String?
  suggestedDate DateTime?
  status        ContentPostStatus @default(IDEA)

  order Int?

  contentPlan ContentPlan @relation(fields: [contentPlanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contentPlanId])
  @@index([contentPlanId, status])
  @@index([contentPlanId, suggestedDate])
  @@map("content_posts")
}

enum PlanType {
  FREE
  PRO
  BUSINESS
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

model Subscription {
  id             String @id @default(cuid())
  organizationId String @unique

  plan   PlanType           @default(FREE)
  status SubscriptionStatus @default(ACTIVE)

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)

  gateway                String?
  externalCustomerId     String?
  externalSubscriptionId String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([plan])
  @@index([status])
  @@map("subscriptions")
}

enum ActivityAction {
  CUSTOMER_CREATED
  CUSTOMER_UPDATED
  CUSTOMER_ARCHIVED

  PRODUCT_SERVICE_CREATED
  PRODUCT_SERVICE_UPDATED
  PRODUCT_SERVICE_ARCHIVED

  TASK_CREATED
  TASK_UPDATED
  TASK_COMPLETED
  TASK_CANCELED

  CONTENT_PLAN_CREATED
  CONTENT_PLAN_UPDATED
  CONTENT_PLAN_APPROVED
  CONTENT_PLAN_ARCHIVED

  CONTENT_POST_CREATED
  CONTENT_POST_UPDATED
  CONTENT_POST_STATUS_CHANGED

  MEMBER_INVITED
  MEMBER_UPDATED
  MEMBER_REMOVED

  SUBSCRIPTION_PLAN_CHANGED
}

enum ActivityEntityType {
  USER
  ORGANIZATION
  ORGANIZATION_MEMBER
  CUSTOMER
  PRODUCT_SERVICE
  TASK
  CONTENT_PLAN
  CONTENT_POST
  SUBSCRIPTION
}

model ActivityLog {
  id             String @id @default(cuid())
  organizationId String

  actorId String?

  action     ActivityAction
  entityType ActivityEntityType?
  entityId   String?

  description String?
  metadata    Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?        @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@index([organizationId, action])
  @@index([actorId])
  @@map("activity_logs")
}